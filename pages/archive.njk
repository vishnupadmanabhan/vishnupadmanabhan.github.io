---
layout: base.njk
title: Archive
permalink: /archive/
---

<section class="archive-page">

  <div class="archive-header">
    <h1 class="now-title">Archive</h1>
    <span class="archive-count">{{ collections.posts.length }} posts</span>
  </div>

  {% for group in collections.postsByYear %}
  <details class="archive-year-group" {% if loop.first %}open{% endif %}>
    <summary class="archive-year">
      <span>{{ group.year }}</span>
      <span class="archive-year-count">{{ group.posts.length }}</span>
    </summary>
    <ol class="post-list archive-year-list">
      {% for post in group.posts %}
      <li class="post-item">
        <div class="post-item-meta">
          <time datetime="{{ post.date | dateISO }}">{{ post.date | dateMonthDay }}</time>
        </div>
        <h3 class="post-item-title">
          <a href="{{ post.url }}">{{ post.data.title | accentTitle | safe }}</a>
        </h3>
      </li>
      {% endfor %}
    </ol>
  </details>
  {% endfor %}

</section>
