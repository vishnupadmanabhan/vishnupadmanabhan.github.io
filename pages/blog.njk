---
layout: base.njk
title: Writing
permalink: /blog/
---

<section class="archive-page">

  <div class="archive-header">
    <div class="now-header-top">
      <h1 class="now-title">Writing</h1>
      <span class="archive-count">{{ collections.posts.length }} posts</span>
    </div>
  </div>

  <ol class="post-list">
    {% for post in collections.posts %}
      {% if loop.index <= 7 %}
      <li class="post-item">
        <article>
          <div class="post-item-meta">
            <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay }}</time>
            <span class="meta-sep">·</span>
            <span>{{ post.templateContent | readingTime }}</span>
          </div>
          <h2 class="post-item-title">
            <a href="{{ post.url }}">{{ post.data.title | accentTitle | safe }}</a>
          </h2>
          {% if post.data.description %}
          <p class="post-item-excerpt">{{ post.data.description }}</p>
          {% endif %}
        </article>
      </li>
      {% endif %}
    {% endfor %}
  </ol>

  {% if collections.posts.length > 7 %}
  <div class="archive-footer">
    <a href="/archive/" class="view-all-link">All posts →</a>
  </div>
  {% endif %}

</section>
