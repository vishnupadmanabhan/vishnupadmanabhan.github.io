---
layout: base.njk
---

<article class="post">

  <header class="post-header">
    <h1 class="post-title">{{ title | accentTitle | safe }}</h1>
    {% if description %}
    <p class="post-subtitle">{{ description }}</p>
    {% endif %}
    <div class="post-meta">
      <time datetime="{{ date | dateISO }}">{{ date | dateDisplay }}</time>
      <span class="meta-sep">·</span>
      <span>{{ content | readingTime }}</span>
      {% if updated %}
      <span class="meta-sep">·</span>
      <span class="post-updated">Updated {{ updated | dateDisplay }}</span>
      {% endif %}
    </div>
  </header>

  <div class="post-body">
    {{ content | safe }}
  </div>

  <footer class="post-footer">
    <a href="/blog" class="back-link">← All posts</a>
  </footer>

</article>
